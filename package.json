{
  "name": "flexbox-trainer",
  "displayName": "FlexBox Trainer",
  "description": "Treinador de recriação de layouts com FlexBox para o VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "browser": "./dist/web/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "flexboxTrainer",
          "title": "FlexBox Trainer",
          "icon": "resources/flexbox-trainer.svg"
        }
      ]
    },
    "views": {
      "flexboxTrainer": [
        {
          "type": "webview",
          "id": "flexbox-trainer.sidebar",
          "name": "Desafio"
        }
      ]
    },
    "commands": [
      {
        "command": "flexbox-trainer.iniciar",
        "title": "FlexBox Trainer: Iniciar"
      }
    ],
    "configuration": {
      "title": "FlexBox Trainer",
      "properties": {
        "flexboxTrainer.apiBaseUrl": {
          "type": "string",
          "default": "",
          "description": "URL base da API de torneio para avaliar tentativas (exemplo: https://api.seudominio.com)."
        }
      }
    }
  },
  "scripts": {
    "test": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. --extensionTestsPath=dist/web/test/suite/index.js",
    "pretest": "npm run compile-web",
    "vscode:prepublish": "npm run package-web",
    "compile-web": "webpack",
    "watch-web": "webpack --watch",
    "package-web": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src",
    "run-in-browser": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. ."
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/assert": "^1.5.11",
    "eslint": "^9.39.3",
    "typescript-eslint": "^8.56.1",
    "mocha": "^11.7.5",
    "typescript": "^5.9.3",
    "@vscode/test-web": "^0.0.80",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@types/webpack-env": "^1.18.8",
    "assert": "^2.1.0",
    "process": "^0.11.10"
  }
}
